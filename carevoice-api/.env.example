# Copy this file to .env and fill in your local values.
# psycopg 3 URL format. For psycopg, the dialect is "postgresql+psycopg".
DATABASE_URL=postgresql+psycopg://carevoice:carevoice@localhost:5432/carevoice

# Comma-separated list of origins allowed by CORS. * = allow any (dev only).
CORS_ORIGINS=*
